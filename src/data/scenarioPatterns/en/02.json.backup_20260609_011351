{
  "it-1": [
    {
      "id": "en-it-1-02-1",
      "pattern": "We need to update the user authentication module to support two-factor authentication.",
      "translations": {
        "zh-TW": "我們需要更新使用者驗證模組，以支援雙重身份驗證。"
      },
      "explanations": {
        "zh-TW": "直接點出技術需求，適合用於需求規格文件開頭，語氣專業明確。"
      }
    },
    {
      "id": "en-it-1-02-2",
      "pattern": "The system should automatically back up user data every 24 hours to prevent data loss.",
      "translations": {
        "zh-TW": "系統應每24小時自動備份使用者資料，以防止資料遺失。"
      },
      "explanations": {
        "zh-TW": "使用'should'表達功能性需求，是撰寫SRS文件時的標準用語。"
      }
    },
    {
      "id": "en-it-1-02-3",
      "pattern": "Could you clarify the expected response time for the API endpoint under peak load conditions?",
      "translations": {
        "zh-TW": "能否請您說明在尖峰負載情況下，API 端點的預期回應時間？"
      },
      "explanations": {
        "zh-TW": "以禮貌問句確認技術細節，展現專業且避免溝通誤解。"
      }
    },
    {
      "id": "en-it-1-02-4",
      "pattern": "Please ensure the new feature is compatible with both iOS and Android platforms before deployment.",
      "translations": {
        "zh-TW": "請確保新功能在上線前，能同時相容於 iOS 與 Android 平台。"
      },
      "explanations": {
        "zh-TW": "使用'please ensure'表達必要條件，常見於跨平台開發需求溝通。"
      }
    },
    {
      "id": "en-it-1-02-5",
      "pattern": "We'd like to request a detailed timeline for the implementation of the reporting dashboard.",
      "translations": {
        "zh-TW": "我們希望能取得報表儀表板實作的詳細時程規劃。"
      },
      "explanations": {
        "zh-TW": "'We'd like to request'是商務郵件中提出需求的委婉說法，維持合作氛圍。"
      }
    }
  ],
  "it-2": [
    {
      "id": "en-it-2-02-1",
      "pattern": "How do I configure the notification settings for real-time alerts?",
      "translations": {
        "zh-TW": "請問我該如何設定即時通知的警示選項？"
      },
      "explanations": {
        "zh-TW": "以'How do I'開頭直接詢問操作步驟，清晰且易於技術支援回覆。"
      }
    },
    {
      "id": "en-it-2-02-2",
      "pattern": "Is there a user guide available for the advanced filtering feature?",
      "translations": {
        "zh-TW": "請問進階篩選功能有提供使用者手冊嗎？"
      },
      "explanations": {
        "zh-TW": "詢問文件資源時使用'Is there...available'，語氣禮貌且專業。"
      }
    },
    {
      "id": "en-it-2-02-3",
      "pattern": "What happens if I accidentally delete a project? Can it be recovered?",
      "translations": {
        "zh-TW": "如果我不小心刪除了專案會怎樣？可以還原嗎？"
      },
      "explanations": {
        "zh-TW": "先描述情境再提問，幫助對方快速理解問題核心。"
      }
    },
    {
      "id": "en-it-2-02-4",
      "pattern": "Could you walk me through the process of exporting data to CSV format?",
      "translations": {
        "zh-TW": "能否請您逐步說明將資料匯出為 CSV 格式的流程？"
      },
      "explanations": {
        "zh-TW": "'walk me through'是母語者常用說法，表達希望獲得逐步指導。"
      }
    },
    {
      "id": "en-it-2-02-5",
      "pattern": "Does the system support keyboard shortcuts for faster navigation?",
      "translations": {
        "zh-TW": "系統是否支援鍵盤快速鍵以提升操作效率？"
      },
      "explanations": {
        "zh-TW": "詢問效率功能時用'Does the system support'，精準且具技術導向。"
      }
    }
  ],
  "it-3": [
    {
      "id": "en-it-3-02-1",
      "pattern": "The backend migration is currently 80% complete, but we've encountered a minor delay with the database indexing.",
      "translations": {
        "zh-TW": "後端遷移目前已完成80%，但我們在資料庫索引建立上遇到輕微延遲。"
      },
      "explanations": {
        "zh-TW": "先報進度再說明阻礙，結構清晰，適合向主管簡報。"
      }
    },
    {
      "id": "en-it-3-02-2",
      "pattern": "We're on track to meet the Q3 deadline, pending final approval from the security team.",
      "translations": {
        "zh-TW": "只要資安團隊完成最終審核，我們就能如期於第三季截止前完成。"
      },
      "explanations": {
        "zh-TW": "'pending'精準表達『待決事項』，展現風險意識與專案管理能力。"
      }
    },
    {
      "id": "en-it-3-02-3",
      "pattern": "One blocker we're facing is the third-party API rate limit; we're exploring caching solutions.",
      "translations": {
        "zh-TW": "目前遇到的阻礙是第三方 API 的呼叫頻率限制，我們正在評估快取解決方案。"
      },
      "explanations": {
        "zh-TW": "使用'blocker'描述關鍵阻礙是專案管理常用術語，專業且精確。"
      }
    },
    {
      "id": "en-it-3-02-4",
      "pattern": "I'll send a detailed status report by EOD today, including risk mitigation steps.",
      "translations": {
        "zh-TW": "我將在今日下班前寄送詳細進度報告，包含風險緩解措施。"
      },
      "explanations": {
        "zh-TW": "'EOD'(End of Day) 是商務常見縮寫，展現效率與時間管理意識。"
      }
    },
    {
      "id": "en-it-3-02-5",
      "pattern": "To stay aligned, could we schedule a quick sync-up tomorrow morning?",
      "translations": {
        "zh-TW": "為確保資訊同步，我們能否安排明天早上快速開個短會？"
      },
      "explanations": {
        "zh-TW": "'stay aligned'與'sync-up'是跨團隊協作的母語表達，自然且具合作感。"
      }
    }
  ],
  "it-4": [
    {
      "id": "en-it-4-02-1",
      "pattern": "For the new search feature, we should prioritize fuzzy matching over exact keyword matching.",
      "translations": {
        "zh-TW": "關於新搜尋功能，我們應優先實作模糊比對，而非精確關鍵字比對。"
      },
      "explanations": {
        "zh-TW": "使用'should prioritize'表達技術建議，語氣堅定但保留討論空間。"
      }
    },
    {
      "id": "en-it-4-02-2",
      "pattern": "What's your take on refactoring the legacy code before adding this module?",
      "translations": {
        "zh-TW": "在新增此模組前，您對重構舊程式碼有什麼看法？"
      },
      "explanations": {
        "zh-TW": "'What's your take on...'是母語者徵詢意見的自然說法，促進團隊共識。"
      }
    },
    {
      "id": "en-it-4-02-3",
      "pattern": "Let's define clear acceptance criteria before we start development to avoid scope creep.",
      "translations": {
        "zh-TW": "我們應在開發前先明確定義驗收標準，以避免範圍蔓延。"
      },
      "explanations": {
        "zh-TW": "'scope creep'是專案管理關鍵術語，展現專業風險意識。"
      }
    },
    {
      "id": "en-it-4-02-4",
      "pattern": "I propose we adopt a feature flag approach to enable gradual rollout and A/B testing.",
      "translations": {
        "zh-TW": "我建議採用功能開關策略，以便逐步上線並進行 A/B 測試。"
      },
      "explanations": {
        "zh-TW": "'I propose'＋專業術語組合，展現技術領導力與前瞻思維。"
      }
    },
    {
      "id": "en-it-4-02-5",
      "pattern": "Can we align on the definition of 'done' for this user story before sprint planning?",
      "translations": {
        "zh-TW": "我們能否在衝刺規劃會前，先對這個使用者故事的『完成』定義達成共識？"
      },
      "explanations": {
        "zh-TW": "敏捷開發常用語，'align on the definition of done'精準表達協作需求。"
      }
    }
  ],
  "it-5": [
    {
      "id": "en-it-5-02-1",
      "pattern": "Thanks everyone for joining; let's quickly recap the action items from last week's sync.",
      "translations": {
        "zh-TW": "感謝各位參與，我們先快速回顧上週會議的待辦事項。"
      },
      "explanations": {
        "zh-TW": "視訊會議開場經典句型，'recap action items'展現效率與追蹤意識。"
      }
    },
    {
      "id": "en-it-5-02-2",
      "pattern": "Sorry, you're on mute—could you please unmute and share your screen?",
      "translations": {
        "zh-TW": "抱歉，您目前處於靜音狀態，能否請您開啟麥克風並分享螢幕？"
      },
      "explanations": {
        "zh-TW": "禮貌提醒技術問題，'you're on mute'是跨國會議高頻實用句。"
      }
    },
    {
      "id": "en-it-5-02-3",
      "pattern": "To ensure clarity across time zones, I'll follow up with meeting notes and recorded video.",
      "translations": {
        "zh-TW": "為確保跨時區溝通清晰，我會會後寄送會議紀錄與錄影連結。"
      },
      "explanations": {
        "zh-TW": "展現跨國協作體貼度，'follow up with'是專業後續追蹤用語。"
      }
    },
    {
      "id": "en-it-5-02-4",
      "pattern": "Let me pause here—does anyone have questions before we move to the next agenda?",
      "translations": {
        "zh-TW": "我先在此暫停，進入下一項議程前，各位是否有任何問題？"
      },
      "explanations": {
        "zh-TW": "主動確認理解度，'Let me pause here'是引導會議節奏的自然說法。"
      }
    },
    {
      "id": "en-it-5-02-5",
      "pattern": "Due to bandwidth constraints, could we keep camera-off for non-presenters to stabilize the connection?",
      "translations": {
        "zh-TW": "考量頻寬限制，能否請非發言者暫時關閉鏡頭以穩定連線？"
      },
      "explanations": {
        "zh-TW": "專業且體貼地提出技術妥協方案，'bandwidth constraints'精準描述問題。"
      }
    }
  ],
  "it-6": [
    {
      "id": "en-it-6-02-1",
      "pattern": "We should implement zero-trust architecture to minimize lateral movement risks in case of breach.",
      "translations": {
        "zh-TW": "我們應實施零信任架構，以在發生資安事件時最小化橫向移動風險。"
      },
      "explanations": {
        "zh-TW": "使用專業術語'zero-trust'＋'lateral movement'展現資安深度知識。"
      }
    },
    {
      "id": "en-it-6-02-2",
      "pattern": "Have we conducted a threat modeling session for this new microservice yet?",
      "translations": {
        "zh-TW": "我們是否已為這個新微服務進行過威脅建模分析？"
      },
      "explanations": {
        "zh-TW": "'threat modeling'是資安開發關鍵流程，問句形式促進團隊檢視。"
      }
    },
    {
      "id": "en-it-6-02-3",
      "pattern": "All API endpoints must enforce HTTPS and validate JWT tokens before processing requests.",
      "translations": {
        "zh-TW": "所有 API 端點必須強制使用 HTTPS，並在處理請求前驗證 JWT 權杖。"
      },
      "explanations": {
        "zh-TW": "'must enforce'表達資安強制規範，語氣堅定且具技術精確度。"
      }
    },
    {
      "id": "en-it-6-02-4",
      "pattern": "Let's schedule a penetration test before the production launch to identify potential vulnerabilities.",
      "translations": {
        "zh-TW": "我們應在上線前安排滲透測試，以識別潛在弱點。"
      },
      "explanations": {
        "zh-TW": "'penetration test'是資安驗證標準流程，展現風險預防意識。"
      }
    },
    {
      "id": "en-it-6-02-5",
      "pattern": "For sensitive data, we need end-to-end encryption both in transit and at rest.",
      "translations": {
        "zh-TW": "針對敏感資料，我們需確保傳輸中與靜態儲存時皆採用端到端加密。"
      },
      "explanations": {
        "zh-TW": "'in transit and at rest'是資安合規關鍵用語，展現專業完整度。"
      }
    }
  ],
  "sales-1": [
    {
      "id": "en-sales-1-02-1",
      "pattern": "Hi, I'm [Name] from [Company]—we help businesses like yours streamline their workflow with AI-powered automation.",
      "translations": {
        "zh-TW": "您好，我是 [公司] 的 [姓名]，我們協助像貴公司這樣的企業，透過 AI 自動化解決方案優化工作流程。"
      },
      "explanations": {
        "zh-TW": "開場自我介紹＋價值主張，'businesses like yours'建立共鳴感。"
      }
    },
    {
      "id": "en-sales-1-02-2",
      "pattern": "Before I dive in, may I ask what your biggest operational challenge is right now?",
      "translations": {
        "zh-TW": "在深入介紹前，能否先請教您目前最大的營運挑戰是什麼？"
      },
      "explanations": {
        "zh-TW": "先提問再推銷，展現以客戶為中心的銷售思維。"
      }
    },
    {
      "id": "en-sales-1-02-3",
      "pattern": "Our solution has helped clients reduce manual processing time by up to 70%—would you like to see a quick demo?",
      "translations": {
        "zh-TW": "我們的解決方案已協助客戶減少高達70%的手動處理時間，您想看看簡短示範嗎？"
      },
      "explanations": {
        "zh-TW": "用數據建立可信度，'would you like'禮貌邀請進入下一階段。"
      }
    },
    {
      "id": "en-sales-1-02-4",
      "pattern": "What sets us apart is our 24/7 dedicated support team and seamless integration with your existing tools.",
      "translations": {
        "zh-TW": "我們的優勢在於提供全天候專屬支援團隊，以及與您現有工具的無縫整合。"
      },
      "explanations": {
        "zh-TW": "強調差異化價值，'What sets us apart'是母語者常用銷售話術。"
      }
    },
    {
      "id": "en-sales-1-02-5",
      "pattern": "If this aligns with your goals, I'd love to schedule a deeper discovery call next week.",
      "translations": {
        "zh-TW": "若這與您的目標相符，我很樂意安排下週進行更深入的需求訪談。"
      },
      "explanations": {
        "zh-TW": "'If this aligns'尊重客戶決策權，'discovery call'是專業銷售流程術語。"
      }
    }
  ],
  "sales-2": [
    {
      "id": "en-sales-2-02-1",
      "pattern": "To tailor our solution, could you share more about your current workflow pain points?",
      "translations": {
        "zh-TW": "為量身打造解決方案，能否請您多分享目前工作流程中的痛點？"
      },
      "explanations": {
        "zh-TW": "'tailor our solution'展現客製化思維，'pain points'是業務需求關鍵詞。"
      }
    },
    {
      "id": "en-sales-2-02-2",
      "pattern": "When you say 'too time-consuming,' what specific tasks are taking up most of your team's hours?",
      "translations": {
        "zh-TW": "當您提到『太耗時』時，具體是哪些任務佔用了團隊最多時間？"
      },
      "explanations": {
        "zh-TW": "追問具體細節，展現深度聆聽與問題診斷能力。"
      }
    },
    {
      "id": "en-sales-2-02-3",
      "pattern": "How are you currently measuring success for this process? Any KPIs we should be aware of?",
      "translations": {
        "zh-TW": "您目前如何衡量此流程的成效？是否有任何我們應留意的關鍵指標？"
      },
      "explanations": {
        "zh-TW": "詢問 KPI 展現專業度，'should be aware of'禮貌確認對齊標準。"
      }
    },
    {
      "id": "en-sales-2-02-4",
      "pattern": "What would an ideal outcome look like for you if we could solve this challenge?",
      "translations": {
        "zh-TW": "如果我們能解決這個挑戰，對您而言理想的成果會是什麼樣子？"
      },
      "explanations": {
        "zh-TW": "引導客戶描繪願景，'ideal outcome'促進價值共創對話。"
      }
    },
    {
      "id": "en-sales-2-02-5",
      "pattern": "Just to confirm I understand correctly—you're looking for a solution that scales with your growth, right?",
      "translations": {
        "zh-TW": "為確認我理解正確：您希望的是能隨著貴公司成長而擴展的解決方案，對嗎？"
      },
      "explanations": {
        "zh-TW": "'Just to confirm'展現細心，結尾用'right?'促進互動確認。"
      }
    }
  ],
  "sales-3": [
    {
      "id": "en-sales-3-02-1",
      "pattern": "I completely understand budget is a concern—many of our clients felt the same way before seeing the ROI.",
      "translations": {
        "zh-TW": "我完全理解預算是一個考量，許多客戶在看到投資報酬率前也有同樣想法。"
      },
      "explanations": {
        "zh-TW": "先同理再轉化，'before seeing the ROI'引導客戶關注長期價值。"
      }
    },
    {
      "id": "en-sales-3-02-2",
      "pattern": "What if we could structure a phased rollout to align costs with your quarterly budget cycles?",
      "translations": {
        "zh-TW": "如果我們能規劃分階段上線，讓成本配合您的季度預算週期，您覺得如何？"
      },
      "explanations": {
        "zh-TW": "提出彈性方案，'What if'開頭促進共同解決問題的思考。"
      }
    },
    {
      "id": "en-sales-3-02-3",
      "pattern": "Let me break down exactly what's included in this pricing—there are no hidden fees, and you get 24/7 support.",
      "translations": {
        "zh-TW": "讓我為您詳細說明此報價包含的內容：無任何隱藏費用，且包含全天候支援。"
      },
      "explanations": {
        "zh-TW": "透明化解釋價格組成，'no hidden fees'消除客戶疑慮。"
      }
    },
    {
      "id": "en-sales-3-02-4",
      "pattern": "Compared to the cost of manual errors you're currently facing, this investment pays for itself in under 6 months.",
      "translations": {
        "zh-TW": "與您目前因手動錯誤產生的成本相比，這項投資不到6個月就能回本。"
      },
      "explanations": {
        "zh-TW": "用客戶現有痛點對比，'pays for itself'強化投資正當性。"
      }
    },
    {
      "id": "en-sales-3-02-5",
      "pattern": "If we can meet your target price, would you be ready to move forward with a pilot project next month?",
      "translations": {
        "zh-TW": "如果我們能符合您的目標價格，您是否準備好下個月啟動試點專案？"
      },
      "explanations": {
        "zh-TW": "條件式促成，'would you be ready'禮貌確認購買意願。"
      }
    }
  ],
  "sales-4": [
    {
      "id": "en-sales-4-02-1",
      "pattern": "Let me share my screen and walk you through the dashboard—notice how real-time data updates automatically here.",
      "translations": {
        "zh-TW": "讓我分享螢幕，帶您瀏覽儀表板—請注意這裡的即時資料會自動更新。"
      },
      "explanations": {
        "zh-TW": "Demo 開場引導，'walk you through'＋'notice how'促進互動觀察。"
      }
    },
    {
      "id": "en-sales-4-02-2",
      "pattern": "This is where the magic happens: with one click, you can generate a full report that used to take hours.",
      "translations": {
        "zh-TW": "這裡是關鍵功能：只需一鍵，就能產生過去需耗時數小時的完整報告。"
      },
      "explanations": {
