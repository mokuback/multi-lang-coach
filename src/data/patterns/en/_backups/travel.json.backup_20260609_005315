      "explanations": {
        "zh-TW": "結帳前確認付款形式。"
      }
    },
    {
      "id": "en-tr-pi8",
      "pattern": "Does this dish contain [Ingredient]?",
      "translations": {
        "zh-TW": "這道料理有包含 [某種食材 (如花生/海鮮)] 嗎？"
      },
      "explanations": {
        "zh-TW": "防範過敏必備的餐廳詢問句。"
      }
    },
    {
      "id": "en-tr-pi9",
      "pattern": "We went to [Place] this morning.",
      "translations": {
        "zh-TW": "我們今天早上去過了 [某個地點]。"
      },
      "explanations": {
        "zh-TW": "跟司機、導遊或是旅伴分享今日行程狀態。"
      }
    },
    {
      "id": "en-tr-pi10",
      "pattern": "Could you take a photo of [Us/Me]?",
      "translations": {
        "zh-TW": "可以請您幫 [我們/我] 拍張照嗎？"
      },
      "explanations": {
        "zh-TW": "觀光景點搭訕路人尋求拍照協助。"
      }
    }
  ]
}