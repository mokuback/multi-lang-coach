        "zh-TW": "最基礎的點餐或要求服務句型。"
      }
    },
    {
      "id": "en-tr-b2",
      "pattern": "Where is [Place]?",
      "translations": {
        "zh-TW": "[某個地點] 在哪裡？"
      },
      "explanations": {
        "zh-TW": "基礎問路。"
      }
    }
