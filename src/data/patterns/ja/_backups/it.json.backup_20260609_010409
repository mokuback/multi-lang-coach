{
  "beginner": [
    {
      "id": "ja-it-b1",
      "pattern": "私は [Software/Tool] を使います。",
      "translations": {
        "zh-TW": "我使用 [某個軟體/工具]。"
      },
      "explanations": {
        "zh-TW": "最簡單的工具介紹句。"
      }
    },
    {
      "id": "ja-it-b2",
      "pattern": "[Device/System] が動いていません。",
      "translations": {
        "zh-TW": "[某個設備/系統] 壞了/沒有運作。"
      },
      "explanations": {
        "zh-TW": "基礎問題回報。"
      }
    }
  ],
  "pre-intermediate": [
    {
      "id": "ja-it-pi1",
      "pattern": "現在、[Task/Project] を担当しています。",
      "translations": {
        "zh-TW": "我現在正在負責 [某個任務/專案]。"
      },
      "explanations": {
        "zh-TW": "日系職場常見的負責任務回報法。"
      }
    },
    {
      "id": "ja-it-pi2",
      "pattern": "[Task] を手伝っていただけますか？",
      "translations": {
        "zh-TW": "你能幫我處理 [某個任務] 嗎？"
      },
      "explanations": {
        "zh-TW": "有禮貌的請託方式。"
      }
    },
    {
      "id": "ja-it-pi3",
      "pattern": "本日、[Task] が完了しました。",
      "translations": {
        "zh-TW": "今天完成了 [某個任務]。"
      },
      "explanations": {
        "zh-TW": "每日朝會或下班前進度回報。"
      }
    },
    {
      "id": "ja-it-pi4",
      "pattern": "[Component] の修正にもう少し時間が必要です。",
      "translations": {
        "zh-TW": "修復 [某個組件] 還需要多一點時間。"
      },
      "explanations": {
        "zh-TW": "報告延遲且禮貌地爭取時間。"
      }
    },
    {
      "id": "ja-it-pi5",
      "pattern": "[File/Module] にエラーが発生しています。",
      "translations": {
        "zh-TW": "[某個檔案/模組] 發生了錯誤。"
      },
      "explanations": {
        "zh-TW": "點出錯誤發生的具體位置。"
      }
    },
    {
      "id": "ja-it-pi6",
      "pattern": "[Feature] のコードレビューをお願いできますか？",
      "translations": {
        "zh-TW": "能麻煩您幫忙對 [某功能] 進行 Code Review 嗎？"
      },
      "explanations": {
        "zh-TW": "委託前輩或同事審查代碼。"
      }
    },
    {
      "id": "ja-it-pi7",
      "pattern": "[Database/Server] に接続しようとしています。",
      "translations": {
        "zh-TW": "我正嘗試連線至 [資料庫/伺服器]。"
      },
      "explanations": {
        "zh-TW": "針對連線動作的說明。"
      }
    },
    {
      "id": "ja-it-pi8",
      "pattern": "[Reason] が原因でサーバーがダウンしています。",
      "translations": {
        "zh-TW": "伺服器因為 [某個原因] 停機了。"
      },
      "explanations": {
        "zh-TW": "說明伺服器癱瘓的原因。"
      }
    },
    {
      "id": "ja-it-pi9",
      "pattern": "[Software] を再インストールしてください。",
      "translations": {
        "zh-TW": "請重新安裝 [某個軟體]。"
      },
      "explanations": {
        "zh-TW": "標準的用戶障礙排除指示。"
      }
    },
    {
      "id": "ja-it-pi10",
      "pattern": "これを [Environment] にデプロイします。",
      "translations": {
        "zh-TW": "我會把它部署到 [某環境]。"
      },
      "explanations": {
        "zh-TW": "宣告將要進行的部署動作。"
      }
    }
  ],
  "intermediate": [
    {
      "id": "ja-it-i1",
      "pattern": "[Module] のバグを修正する必要があります。",
      "translations": {
        "zh-TW": "我們必須修復 [某模組] 的 Bug。"
      },
      "explanations": {
        "zh-TW": "釐清接下來待辦的優先事項。"
      }
    },
    {
      "id": "ja-it-i2",
      "pattern": "[Project] の進捗はどうですか？",
      "translations": {
        "zh-TW": "[某專案] 的進度如何？"
      },
      "explanations": {
        "zh-TW": "主管或 PM 常用的詢問方式。"
      }
    },
    {
      "id": "ja-it-i3",
      "pattern": "この問題の根本原因は [Technical Cause] です。",
      "translations": {
        "zh-TW": "這個問題的根本原因在於 [技術性原因]。"
      },
      "explanations": {
        "zh-TW": "深入探討障害原因（根本原因/ルートコーズ）的用語。"
      }
    },
    {
      "id": "ja-it-i4",
      "pattern": "デプロイを [Previous Version] に切り戻しましょう。",
      "translations": {
        "zh-TW": "我們把部署退版（切回）到 [上一個版本] 吧。"
      },
      "explanations": {
        "zh-TW": "日文中「退版」常說「切り戻す (きりもどす)」。"
      }
    },
    {
      "id": "ja-it-i5",
      "pattern": "この機能は [API/Service] に依存しています。",
      "translations": {
        "zh-TW": "這個功能依賴於 [某個 API / 服務]。"
      },
      "explanations": {
        "zh-TW": "系統架構與相依性的解說。"
      }
    },
    {
      "id": "ja-it-i6",
      "pattern": "[Feature] のプルリク（PR）を提出します。",
      "translations": {
        "zh-TW": "我要發送 [某功能] 的 PR。"
      },
      "explanations": {
        "zh-TW": "日常開發交流，日文口語常將 Pull Request 簡稱「プルリク」。"
      }
    },
    {
      "id": "ja-it-i7",
      "pattern": "[System/Repository] へのアクセス権限を付与していただけますか？",
      "translations": {
        "zh-TW": "您可以賦予我 [某系統/庫] 的存取權限嗎？"
      },
      "explanations": {
        "zh-TW": "非常有禮貌的申請權限句型。"
      }
    },
    {
      "id": "ja-it-i8",
      "pattern": "現在、[Service] に遅延（レイテンシ）が発生しております。",
      "translations": {
        "zh-TW": "目前 [某服務] 產生了延遲問題。"
      },
      "explanations": {
        "zh-TW": "對客戶或主管發送的錯誤速報（一次報）標準寫法。"
      }
    },
    {
      "id": "ja-it-i9",
      "pattern": "[Component] でメモリリークが起きているようです。",
      "translations": {
        "zh-TW": "似乎在 [某個組件] 發生了 Memory Leak。"
      },
      "explanations": {
        "zh-TW": "開發者之間討論效能瓶頸的推測。"
      }
    },
    {
      "id": "ja-it-i10",
      "pattern": "[Microservice] のインスタンスをスケールアウトしましょう。",
      "translations": {
        "zh-TW": "我們來增加 [某微服務] 的實例來擴容（Scale Out）吧。"
      },
      "explanations": {
        "zh-TW": "伺服器承載量管理的提案。"
      }
    }
  ]
}