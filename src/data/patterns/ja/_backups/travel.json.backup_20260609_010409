{
  "beginner": [
    {
      "id": "ja-tr-b1",
      "pattern": "[Item] をお願いします。",
      "translations": {
        "zh-TW": "麻煩給我 [某物]。"
      },
      "explanations": {
        "zh-TW": "日本最管用、點餐與買東西通殺的用法。"
      }
    },
    {
      "id": "ja-tr-b2",
      "pattern": "[Place] はどこですか？",
      "translations": {
        "zh-TW": "[某個地點] 在哪裡？"
      },
      "explanations": {
        "zh-TW": "基礎問路。"
      }
    }
  ],
  "pre-intermediate": [
    {
      "id": "ja-tr-pi1",
      "pattern": "おすすめの [Food/Place] はありますか？",
      "translations": {
        "zh-TW": "有推薦的 [某食物/地點] 嗎？"
      },
      "explanations": {
        "zh-TW": "請別人推薦的必學實用句。"
      }
    },
    {
      "id": "ja-tr-pi2",
      "pattern": "[Name] で予約している者です。",
      "translations": {
        "zh-TW": "我們是用 [某姓名] 預約的客人。"
      },
      "explanations": {
        "zh-TW": "走進高級旅店或是居酒屋時，非常道地的報到方式。"
      }
    },
    {
      "id": "ja-tr-pi3",
      "pattern": "[Item] をもう一ついただけますか？",
      "translations": {
        "zh-TW": "可以再給我一個 [某物] 嗎？"
      },
      "explanations": {
        "zh-TW": "需要追加餐具或備品時的禮貌說法。"
      }
    },
    {
      "id": "ja-tr-pi4",
      "pattern": "[Item/Ticket] はいくらですか？",
      "translations": {
        "zh-TW": "[某物品/車票] 多少錢？"
      },
      "explanations": {
        "zh-TW": "詢問價格。"
      }
    },
    {
      "id": "ja-tr-pi5",
      "pattern": "この近くに [Facility] はありますか？",
      "translations": {
        "zh-TW": "這附近有 [某設施 (如便利商店)] 嗎？"
      },
      "explanations": {
        "zh-TW": "詢問地緣周遭設施用。"
      }
    },
    {
      "id": "ja-tr-pi6",
      "pattern": "[Time] にチェックインしたいのですが。",
      "translations": {
        "zh-TW": "我想要在 [某個時間] 辦理入住（可是...）。"
      },
      "explanations": {
        "zh-TW": "日式特有的委婉請求語氣（加上 が）。"
      }
    },
    {
      "id": "ja-tr-pi7",
      "pattern": "[Payment Method] で支払えますか？",
      "translations": {
        "zh-TW": "可以用 [某種付款方式 (如信用卡/交通卡)] 付款嗎？"
      },
      "explanations": {
        "zh-TW": "購物付款前的確認。"
      }
    },
    {
      "id": "ja-tr-pi8",
      "pattern": "これに [Ingredient] は入っていますか？",
      "translations": {
        "zh-TW": "這個裡面有加了 [某食材 (如豬肉/蝦)] 嗎？"
      },
      "explanations": {
        "zh-TW": "忌口或防過敏時，針對菜單或商品的詢問。"
      }
    },
    {
      "id": "ja-tr-pi9",
      "pattern": "今朝、[Place] に行ってきました。",
      "translations": {
        "zh-TW": "今天早上我去了 [某地點] 回來了。"
      },
      "explanations": {
        "zh-TW": "表示完成了該行程，用「てきました」強調動作歸來。"
      }
    },
    {
      "id": "ja-tr-pi10",
      "pattern": "写真を撮っていただけませんか？（[Us/Me] の）",
      "translations": {
        "zh-TW": "可以請您幫忙拍張照嗎？（拍我們/我）"
      },
      "explanations": {
        "zh-TW": "在日本觀光聖地請路人幫忙拍照的得體說法。"
      }
    }
  ]
}